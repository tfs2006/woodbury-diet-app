# Environment Variables
# Copy this file to .env.local and fill in the values

# Database configuration
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=woodbury_diet
DB_USER=postgres
DB_PASSWORD=change-me

# Optional alternative to the DB_* variables above
# DATABASE_URL=postgresql://postgres:change-me@127.0.0.1:5432/woodbury_diet

# OpenRouter API Key (required for AI meal planning)
OPENROUTER_API_KEY=your-openrouter-api-key

# NextAuth Secret (generate a strong random value for each environment)
NEXTAUTH_SECRET=generate-a-unique-secret-for-this-environment

# NextAuth URL
NEXTAUTH_URL=http://localhost:3000
